@model BlogSystem.Application.DTOs.Shared.PagedResultDto<BlogSystem.Application.DTOs.Post.PostDto>
@using System.Text.RegularExpressions
@using System.Security.Claims
@{
    ViewData["Title"] = "Posts";
    var isLoggedIn = User.Identity?.IsAuthenticated == true;
    var userId = isLoggedIn ? User.FindFirstValue(ClaimTypes.NameIdentifier) : null;
    var isAdmin = isLoggedIn && User.IsInRole("Admin");
    var isMyPosts = ViewData["IsMyPosts"] as bool? ?? false;
    var searchQuery = Context.Request.Query["search"].ToString();
}

<style>
    :root {
        --primary: #3b82f6;
        --success: #10b981;
        --danger: #ef4444;
        --dark-bg: #0b1220;
        --card-bg: rgba(255, 255, 255, 0.04);
        --card-border: rgba(255, 255, 255, 0.08);
        --text-primary: #f1f5f9;
        --text-muted: #94a3b8;
    }

    .empty-state {
        text-align: center;
        margin: 50px auto;
        padding: 50px 30px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 30px;
        backdrop-filter: blur(20px);
        max-width: 520px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.4);
    }

    .empty-icon {
        font-size: 4rem;
        margin-bottom: 15px;
        animation: floatIcon 3s ease-in-out infinite;
    }

    @@keyframes floatIcon {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(-12px); }
    }

    .empty-title {
        font-size: 2rem;
        font-weight: 700;
        background: linear-gradient(135deg, #a78bfa, #60a5fa);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin-bottom: 10px;
    }

    .empty-description {
        color: #cbd5e1;
        font-size: 1rem;
        margin: 10px 0 25px;
        line-height: 1.5;
    }

    .empty-btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 28px;
        border-radius: 50px;
        font-weight: 600;
        font-size: 0.95rem;
        text-decoration: none;
        transition: all 0.25s ease;
        background: linear-gradient(135deg, #6366f1, #3b82f6);
        color: white;
        border: none;
        box-shadow: 0 8px 20px rgba(79,70,229,0.4);
    }

    .empty-btn:hover {
        transform: translateY(-3px);
        box-shadow: 0 12px 28px rgba(99,102,241,0.6);
        background: linear-gradient(135deg, #4f46e5, #2563eb);
    }

    body {
        background: var(--dark-bg);
        font-family: 'Inter', sans-serif;
    }

    .container {
        max-width: 1000px;
        margin: 48px auto 0;
        padding: 0 25px;
    }

    .header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 40px;
        flex-wrap: nowrap;
        gap: 20px;
    }

    .search-create {
        display: flex;
        align-items: center;
        gap: 15px;
        flex-wrap: nowrap;
        flex-shrink: 0;
    }

    .search-create > * {
        flex-shrink: 0;
    }

    .search-box {
        display: flex;
        gap: 10px;
        align-items: center;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 50px;
        padding: 5px 5px 5px 20px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        backdrop-filter: blur(10px);
        flex-shrink: 0;
    }

    .search-box input {
        background: transparent;
        border: none;
        outline: none;
        color: white;
        width: 180px;
        font-size: 0.95rem;
        padding: 6px 0;
    }

    .search-box input::placeholder {
        color: rgba(255,255,255,0.4);
    }

    .btn {
        padding: 10px 22px;
        border-radius: 30px;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: all 0.25s ease;
        border: none;
        cursor: pointer;
        font-size: 0.9rem;
        letter-spacing: 0.3px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.2);
    }

    .btn-primary {
        background: var(--primary);
        color: white;
    }

    .btn-primary:hover {
        background: #2563eb;
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(59,130,246,0.4);
    }

    .btn-success {
        background: linear-gradient(135deg, #10b981, #059669);
        color: white;
    }

    .btn-success:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(16,185,129,0.4);
    }

    .btn-outline {
        background: transparent;
        border: 1.5px solid rgba(255,255,255,0.25);
        color: white;
    }

    .btn-outline:hover {
        background: rgba(255,255,255,0.08);
        border-color: white;
        transform: translateY(-2px);
    }

    .post-card {
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        padding: 30px;
        border-radius: 24px;
        margin-bottom: 25px;
        backdrop-filter: blur(15px);
        transition: transform 0.2s, box-shadow 0.3s;
        box-shadow: 0 20px 40px -15px rgba(0,0,0,0.5);
    }

    .post-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 30px 50px -20px rgba(0,0,0,0.7);
        border-color: rgba(99,102,241,0.3);
    }

    .post-card .title {
        font-size: 1.7rem;
        font-weight: 700;
        margin-bottom: 12px;
        color: var(--text-primary);
        line-height: 1.3;
    }

    .post-card .content {
        color: var(--text-muted);
        line-height: 1.7;
        font-size: 0.95rem;
        margin-bottom: 20px;
    }

    .post-card .meta {
        display: flex;
        align-items: center;
        gap: 15px;
        font-size: 0.8rem;
        color: var(--text-muted);
        margin-bottom: 25px;
        flex-wrap: wrap;
    }

    .meta .author-avatar {
        width: 28px;
        height: 28px;
        background: linear-gradient(135deg, #6366f1, #3b82f6);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.7rem;
        font-weight: bold;
    }

    .action-buttons {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
    }

    .btn-action {
        padding: 10px 24px;
        border-radius: 25px;
        font-weight: 600;
        font-size: 0.85rem;
        display: flex;
        align-items: center;
        gap: 6px;
        transition: all 0.2s;
        background: transparent;
        color: white;
        border: 1.5px solid;
    }

    .btn-read {
        border-color: #3b82f6;
        background: rgba(59,130,246,0.1);
    }

    .btn-read:hover {
        background: #3b82f6;
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(59,130,246,0.4);
    }

    .btn-edit {
        border-color: #10b981;
        background: rgba(16,185,129,0.1);
    }

    .btn-edit:hover {
        background: #10b981;
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(16,185,129,0.4);
    }

    .btn-delete {
        border-color: #ef4444;
        background: rgba(239,68,68,0.1);
        cursor: pointer;
    }

    .btn-delete:hover {
        background: #ef4444;
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(239,68,68,0.4);
    }

    .pagination {
        display: flex;
        justify-content: center;
        gap: 10px;
        margin-top: 50px;
    }

    .page-btn {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 12px;
        background: rgba(255,255,255,0.05);
        color: white;
        text-decoration: none;
        font-weight: 600;
        transition: 0.2s;
        border: 1px solid rgba(255,255,255,0.05);
    }

    .page-btn:hover {
        background: var(--primary);
        border-color: var(--primary);
        transform: scale(1.1);
    }

    .btn-delete-form {
        display: inline;
    }
</style>

<div class="container">
    <div class="header">
        <a asp-controller="Post" asp-action="Index" style="font-size: 2.8rem; font-weight: 700; letter-spacing: -1px; text-decoration: none; background: linear-gradient(135deg, #6366f1, #3b82f6); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; flex-shrink: 0;">
            📝 Posts
        </a>
        <div class="search-create">
            <form class="search-box" method="get" asp-action="@(isMyPosts ? "MyPosts" : "Index")" asp-controller="Post">
                <input name="search" value="@searchQuery" placeholder="Search posts..." />
                <button type="submit" class="btn btn-primary" style="padding: 10px 20px;">🔍 Search</button>
                @if (!string.IsNullOrEmpty(searchQuery))
                {
                    <a href="@Url.Action(isMyPosts ? "MyPosts" : "Index", "Post")" class="btn btn-outline" style="margin-left: 5px;">✕ Clear</a>
                }
            </form>
            @if (isLoggedIn)
            {
                <a asp-controller="Post" asp-action="Create" asp-route-source="@(isMyPosts ? "my" : "all")" class="btn btn-success">➕ Create Post</a>
            }
        </div>
    </div>

    <form id="searchForm" method="get" action="/posts" style="display:none;"></form>

    @foreach (var post in Model.Items)
    {
        var slug = Regex.Replace(post.Title.ToLower(), @"[^a-z0-9\s-]", "").Trim().Replace(' ', '-');
        var isAuthor = isLoggedIn && post.AuthorId.ToString() == userId;
        var canEdit = isLoggedIn && (isAdmin || isAuthor);
        var canDelete = isLoggedIn && (isAdmin || isAuthor);

        <div class="post-card">
            <div class="title">@post.Title</div>
            <div class="content">
                @(post.Content.Length > 220 ? post.Content.Substring(0, 220) + "..." : post.Content)
            </div>
            <div class="meta">
                <div class="author-avatar">@post.AuthorName[0].ToString().ToUpper()</div>
                <span>@post.AuthorName</span>
                <span>•</span>
                <span>@post.PublishDate.ToString("MMM dd, yyyy")</span>
                <span>•</span>
                <span>@post.AuthorEmail</span>
            </div>
            <div class="action-buttons">
                <a asp-controller="Post" asp-action="Details" asp-route-id="@post.Id" asp-route-slug="@slug" asp-route-source="@(isMyPosts ? "my" : "all")" class="btn-action btn-read">📖 Read More</a>
                @if (canEdit)
                {
                    <a asp-controller="Post" asp-action="Edit" asp-route-id="@post.Id" asp-route-source="@(isMyPosts ? "my" : "all")" class="btn-action btn-edit">✏️ Edit</a>
                }
                @if (canDelete)
                {
                    <form asp-controller="Post" asp-action="Delete" asp-route-id="@post.Id" method="post" class="btn-delete-form" onsubmit="return confirm('Are you sure you want to delete this post?');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="source" value="@(isMyPosts ? "my" : "all")" />
                        <button type="submit" class="btn-action btn-delete">🗑️ Delete</button>
                    </form>
                }
            </div>
        </div>
    }

    @if (!Model.Items.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">📝</div>
            @if (isMyPosts)
            {
                <h2 class="empty-title">Your Story Begins Here</h2>
                <p class="empty-description">The world deserves to hear your voice. Write your first post and inspire someone.</p>
                <a asp-controller="Post" asp-action="Create" class="empty-btn">✨ Create Your First Post</a>
            }
            else
            {
                <h2 class="empty-title">No Posts Yet</h2>
                <p class="empty-description">Be the pioneer! Start a conversation and share your knowledge.</p>
                @if (isLoggedIn)
                {
                    <a asp-controller="Post" asp-action="Create" class="empty-btn">➕ Create a Post</a>
                }
            }
        </div>
    }

    @if (Model.TotalCount > Model.PageSize)
    {
        <div class="pagination">
            @for (int i = 1; i <= Math.Ceiling((double)Model.TotalCount / Model.PageSize); i++)
            {
                <a class="page-btn" href="@Url.Action(isMyPosts ? "MyPosts" : "Index", "Post", new { page = i, search = searchQuery })">@i</a>
            }
        </div>
    }
</div>
