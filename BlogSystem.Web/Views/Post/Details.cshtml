@model BlogSystem.Web.Models.Post.PostDetailsViewModel

@{
ViewData["Title"] = Model.Title;
Layout = "_Layout";
}

<style>

    .details-container {
        max-width: 700px;
        margin: 50px auto;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 30px;
        border-radius: 16px;
        backdrop-filter: blur(10px);
        box-shadow: 0 0 40px rgba(0,0,0,0.6);
        color: white;
    }
    .title { font-size: 26px; font-weight: bold; margin-bottom: 15px; }
    .meta { font-size: 13px; color: #94a3b8; margin-bottom: 20px; }
    .content { font-size: 15px; line-height: 1.6; color: #cbd5e1; white-space: pre-line; }
    .btn-back {
        margin-top: 25px;
        display: inline-block;
        padding: 10px 16px;
        border-radius: 10px;
        text-decoration: none;
        background: linear-gradient(90deg, #3b82f6, #6366f1);
        color: white;
        font-weight: bold;
        transition: 0.3s;
    }
</style>

<div class="details-container">
    <div class="title">@Model.Title</div>

    <div class="meta">
        Author: @Model.AuthorName | @Model.PublishDate.ToString("yyyy-MM-dd")
    </div>

    <div class="content">
        @Model.Content
    </div>

    <a class="btn-back" href="/posts">← Back to Posts</a>
</div>
