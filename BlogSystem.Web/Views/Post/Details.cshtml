@model BlogSystem.Web.Models.Post.PostDetailsViewModel

@{
    ViewData["Title"] = Model.Title;
    Layout = "_Layout";
}

<link rel="stylesheet" href="~/css/post-details.css" />

<div class="details-container">
    <div class="post-card">
        <div class="title">@Model.Title</div>

        <div class="meta">
            <div class="author-avatar">@Model.AuthorName[0].ToString().ToUpper()</div>
            <span>@Model.AuthorName</span>
            <span>•</span>
            <span>@Model.PublishDate.ToString("MMM dd, yyyy")</span>
        </div>

        <div class="content">
            @Model.Content
        </div>

        @{
            var backController = ViewBag.BackController as string ?? "Post";
            var backAction = ViewBag.BackAction as string ?? "Index";
            var backText = ViewBag.BackText as string ?? "← Back to Posts";
        }

        <a asp-controller="@backController" asp-action="@backAction" class="btn-back">@backText</a>
    </div>
</div>
