@model BlogSystem.Web.Models.Post.EditPostViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Edit Post</title>

    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: linear-gradient(135deg, #0f172a, #020617);
            min-height: 100vh;
            color: white;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .container {
            width: 520px;
            padding: 35px;
            border-radius: 18px;
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.08);
            backdrop-filter: blur(12px);
            box-shadow: 0 15px 40px rgba(0,0,0,0.5);
        }

        h2 {
            text-align: center;
            margin-bottom: 25px;
            font-size: 26px;
        }

        input, textarea {
            width: 100%;
            padding: 12px;
            margin-bottom: 15px;
            border-radius: 10px;
            border: none;
            outline: none;
            background: rgba(255,255,255,0.08);
            color: white;
            font-size: 14px;
        }

        textarea {
            height: 180px;
            resize: none;
        }

        button {
            width: 100%;
            padding: 12px;
            border-radius: 10px;
            border: none;
            cursor: pointer;
            font-weight: bold;
            background: linear-gradient(90deg, #3b82f6, #6366f1);
            color: white;
        }

        .back {
            display: block;
            text-align: center;
            margin-top: 15px;
            color: #94a3b8;
            text-decoration: none;
            font-size: 13px;
        }

        .back:hover {
            color: white;
        }
    </style>
</head>

<body>

<div class="container">

    <h2>Edit Post</h2>

    <form method="post" action="/posts/edit/@Model.Id">

        <input type="hidden" name="Id" value="@Model.Id" />

        <input type="text" name="Title" value="@Model.Title" placeholder="Title" />

        <textarea name="Content" placeholder="Content">@Model.Content</textarea>

        <button type="submit">Update Post</button>

    </form>

    <a class="back" href="/posts">← Back to Posts</a>

</div>

</body>
</html>
