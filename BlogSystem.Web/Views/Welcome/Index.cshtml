@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Welcome - BlogSystem</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">

    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', sans-serif;
            background: #0b1220; /* same as _Layout */
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 30px;
        }

        .landing-container {
            max-width: 950px;
            width: 100%;
            text-align: center;
        }

        .header-title {
            font-size: 3.5rem;
            font-weight: 800;
            background: linear-gradient(to right, #a78bfa, #60a5fa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 15px;
        }

        .subtitle {
            font-size: 1.15rem;
            color: #94a3b8;
            margin-bottom: 60px;
        }

        .card-grid {
            display: flex;
            gap: 30px;
            flex-wrap: wrap;
            justify-content: center;
        }

        .feature-card {
            background: rgba(255, 255, 255, 0.04);
            backdrop-filter: blur(15px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 24px;
            padding: 40px 30px;
            flex: 1 1 280px;
            max-width: 360px;
            display: flex;
            flex-direction: column;
            align-items: center;
            color: white;
            transition: all 0.3s ease;
            box-shadow: 0 20px 40px -15px rgba(0,0,0,0.6);
            position: relative;
            overflow: hidden;
        }

        .feature-card::before {
            content: '';
            position: absolute;
            top: -2px;
            left: -2px;
            right: -2px;
            bottom: -2px;
            background: linear-gradient(45deg, #6366f1, #3b82f6, #10b981, #6366f1);
            background-size: 300% 300%;
            border-radius: 26px;
            z-index: -1;
            opacity: 0;
            transition: opacity 0.3s;
        }

        .feature-card:hover::before {
            opacity: 1;
        }

        .feature-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 30px 50px -20px rgba(99,102,241,0.4);
            border-color: transparent;
        }

        .feature-card .icon {
            font-size: 3.5rem;
            margin-bottom: 20px;
            background: none;
            -webkit-background-clip: unset;
            -webkit-text-fill-color: unset;
        }

        .feature-card h3 {
            font-size: 1.7rem;
            font-weight: 700;
            margin-bottom: 12px;
            color: #f1f5f9;
        }

        .feature-card p {
            color: #94a3b8;
            flex-grow: 1;
            margin-bottom: 25px;
            line-height: 1.5;
            font-size: 0.95rem;
        }

        .btn-landing {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 12px 28px;
            border-radius: 50px;
            font-weight: 700;
            font-size: 1rem;
            text-decoration: none;
            transition: all 0.25s ease;
            background: linear-gradient(135deg, #6366f1, #3b82f6);
            color: white;
            border: none;
            box-shadow: 0 8px 20px rgba(79,70,229,0.3);
            letter-spacing: 0.5px;
        }

        .btn-landing:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 28px rgba(99,102,241,0.6);
            background: linear-gradient(135deg, #4f46e5, #2563eb);
        }

        @@media (max-width: 768px) {
            .header-title { font-size: 2.5rem; }
            .landing-container { padding: 40px 15px; }
        }
    </style>
</head>
<body>
    <div class="landing-container">
        <h1 class="header-title">🚀 BlogSystem</h1>
        <p class="subtitle">Discover, create, and share stories. Choose your path below.</p>

        <div class="card-grid">
            <div class="feature-card">
                <div class="icon">🖥️</div>
                <h3>Web App</h3>
                <p>Explore posts, manage content, and interact with a modern, intuitive interface.</p>
                <a asp-controller="Home" asp-action="Index" class="btn-landing">Launch App 🚀</a>
            </div>

            <div class="feature-card">
                <div class="icon">⚙️</div>
                <h3>API Docs</h3>
                <p>Test endpoints, view schemas, and integrate with our RESTful API seamlessly.</p>
                <a href="/swagger" target="_blank" class="btn-landing">Open Swagger 🧪</a>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
