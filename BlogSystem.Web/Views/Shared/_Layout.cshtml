<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BlogSystem</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: #0b1220;
            color: #e5e7eb;
            padding-top: 80px;
        }

        /* კონტეინერის გასწორება - რომ არ გაიჭიმოს და არ მიეჭყლიტოს */
        .container {
            max-width: 1000px;
            margin: auto;
            padding-left: 20px;
            padding-right: 20px;
        }

        .navbar {
            background: rgba(17, 24, 39, 0.85);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(255,255,255,0.05);
        }

        .navbar-brand {
            font-weight: 700;
            letter-spacing: 0.5px;
            font-size: 1.5rem;
        }

        .nav-link {
            color: #cbd5e1 !important;
            transition: 0.2s;
            font-weight: 500;
        }

        .nav-link:hover {
            color: #ffffff !important;
        }

        .btn-primary {
            background: linear-gradient(135deg, #6366f1, #3b82f6);
            border: none;
            border-radius: 10px;
            padding: 8px 20px;
            transition: 0.2s;
            font-weight: 600;
        }

        .btn-primary:hover {
            transform: scale(1.05);
            background: linear-gradient(135deg, #4f46e5, #2563eb);
        }

        .card {
            background: #111827;
            border: 1px solid rgba(255,255,255,0.05);
            border-radius: 14px;
        }
    </style>
</head>

<body>

<header>
    <nav class="navbar navbar-expand-lg navbar-dark fixed-top">
        <div class="container">
            <a class="navbar-brand text-white" asp-controller="Home" asp-action="Index">
                🚀 BlogSystem
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navContent">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navContent">
                <ul class="navbar-nav me-auto gap-3">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Post" asp-action="Index">Posts</a>
                    </li>
                </ul>

                <ul class="navbar-nav align-items-center gap-3">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Auth" asp-action="Login">Login</a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-primary" asp-controller="Auth" asp-action="Register">
                            Register
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
</header>

<main class="container py-4">
    @RenderBody()
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/api.js"></script>

</body>
</html>
