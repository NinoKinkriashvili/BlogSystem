@{
    ViewData["Title"] = "Home Page";
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <h1 class="display-4 text-white">🚀 Welcome to BlogSystem 🚀</h1>
        <p class="text-secondary">Choose how you want to interact with the system:</p>
    </div>

    <div class="row mt-5 justify-content-center gap-4 align-items-stretch">

        <div class="col-md-4 d-flex">
            <div class="card p-4 shadow-sm border-0 bg-dark text-white flex-fill d-flex flex-column">
                <h3 class="mb-3">🖥️ User Interface</h3>
                <p class="flex-grow-1">See the application in action.</p>
                <div class="mt-auto">
                    <a asp-controller="Post" asp-action="Index" class="btn btn-primary w-100">
                        Go to Website 🚀
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4 d-flex">
            <div class="card p-4 shadow-sm border-0 bg-dark text-white flex-fill d-flex flex-column">
                <h3 class="mb-3">⚙️ API Documentation</h3>
                <p class="flex-grow-1">Explore endpoints and test logic.</p>
                <div class="mt-auto">
                    <a href="/swagger" target="_blank" class="btn btn-primary w-100">
                        Open Swagger 🚀
                    </a>
                </div>
            </div>
        </div>

    </div>
</div>
